{
  "name": "jobob-functions",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "멀티캠퍼스 점심 식단을 매일 오전 Mattermost 채널로 전송하는 Firebase Cloud Function",
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@pmh-only/welplan2-model": "latest",
    "@pmh-only/welplan2-welstory-plus": "latest",
    "firebase-admin": "^13.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  }
}
